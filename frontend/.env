# ──────────────────────────────────────────────────────
# Local Event Helper – Frontend Environment Variables
# ──────────────────────────────────────────────────────

# App
VITE_APP_NAME="Local Event Helper"
VITE_APP_URL=http://localhost:5173

# Laravel backend API
VITE_API_URL=http://localhost:8000/api
VITE_API_VERSION=v1

# Auth
VITE_AUTH_TOKEN_KEY=leh_token

# Feature flags
VITE_ENABLE_SOCIAL_LOGIN=false
VITE_ENABLE_NOTIFICATIONS=true
